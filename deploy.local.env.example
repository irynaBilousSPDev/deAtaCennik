# Copy to deploy.local.env and fill in (deploy.local.env is gitignored).
# Use the same host/user/port as PhpStorm SFTP or your hosting panel.

SFTP_HOST=dev.akademiata.pl
SFTP_PORT=22
SFTP_USER=your_sftp_username
SFTP_REMOTE_PATH=/wp-content/themes/akademiata

# Password auth (typical shared hosting):
SFTP_USE_PASSWORD=true
SFTP_PASSWORD=your_sftp_password
# SFTP_PRIVATE_KEY=C:\Users\Ata\.ssh\id_rsa

# Optional
# SKIP_BUILD=true
# DRY_RUN=true
