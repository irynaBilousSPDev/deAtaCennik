# Normalize line endings to LF for all text files across machines.
* text=auto eol=lf

# Explicit text types (theme source)
*.php   text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.html  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.po    text eol=lf
*.pot   text eol=lf

# Binary assets — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.mo    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.pdf   binary
